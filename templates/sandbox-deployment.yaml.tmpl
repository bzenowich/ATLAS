apiVersion: apps/v1
kind: Deployment
metadata:
  name: sandbox
  namespace: ${ATLAS_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: sandbox
  template:
    metadata:
      labels:
        app: sandbox
    spec:
      containers:
      - name: sandbox
        image: ${ATLAS_REGISTRY}/sandbox:${ATLAS_IMAGE_TAG}
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 8020
        securityContext:
          allowPrivilegeEscalation: false
          runAsNonRoot: true
          runAsUser: 1000
---
apiVersion: v1
kind: Service
metadata:
  name: sandbox
  namespace: ${ATLAS_NAMESPACE}
spec:
  type: NodePort
  ports:
  - port: 8020
    targetPort: 8020
    nodePort: ${ATLAS_SANDBOX_NODEPORT}
  selector:
    app: sandbox
