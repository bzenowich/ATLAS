apiVersion: apps/v1
kind: Deployment
metadata:
  name: v3-service
  namespace: ${ATLAS_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: v3-service
  template:
    metadata:
      labels:
        app: v3-service
    spec:
      containers:
      - name: v3-service
        image: ${ATLAS_REGISTRY}/v3-service:${ATLAS_IMAGE_TAG}
        imagePullPolicy: IfNotPresent
        env:
        - name: ATLAS_INFERENCE_URL
          value: http://llama-server:8080
        - name: ATLAS_LENS_URL
          value: http://geometric-lens:8099
        - name: ATLAS_SANDBOX_URL
          value: http://sandbox:8020
        - name: ATLAS_MODEL_NAME
          value: Qwen3.5-9B-Q6_K
        ports:
        - containerPort: 8070
---
apiVersion: v1
kind: Service
metadata:
  name: v3-service
  namespace: ${ATLAS_NAMESPACE}
spec:
  type: NodePort
  ports:
  - port: 8070
    targetPort: 8070
    nodePort: ${ATLAS_V3_NODEPORT}
  selector:
    app: v3-service
